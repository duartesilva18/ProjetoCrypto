# ──────────────────────────────────────────────
# ProjetoCrypto - Environment Configuration
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# ── Bot Mode ──────────────────────────────────
BOT_MODE=paper                     # paper | live
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR

# ── Database ──────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=projetocrypto
POSTGRES_USER=trader
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Redis ─────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Exchange API Keys ─────────────────────────
# IMPORTANT: Create keys with TRADE-ONLY permissions.
# NEVER enable withdrawal permissions.

BINANCE_API_KEY=
BINANCE_API_SECRET=

BYBIT_API_KEY=
BYBIT_API_SECRET=

OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

# ── Strategy Parameters ──────────────────────
FUNDING_RATE_ENTRY_THRESHOLD=0.0001    # 0.01% minimum rate to enter
FUNDING_RATE_EXIT_THRESHOLD=0.00005    # 0.005% rate to exit
MIN_OPPORTUNITY_SCORE=0.5              # 0-1 score threshold

# ── Risk Limits ───────────────────────────────
MAX_EXPOSURE_PER_EXCHANGE=0.30         # 30% of capital per exchange
MAX_EXPOSURE_PER_PAIR=0.10             # 10% of capital per pair
MAX_DAILY_DRAWDOWN=0.02                # 2% soft limit
MAX_DAILY_DRAWDOWN_HARD=0.03           # 3% hard limit (circuit breaker)
MARGIN_BUFFER=0.30                     # 30% buffer above required margin

# ── Execution ─────────────────────────────────
TWAP_STEPS=3                           # number of order steps
TWAP_STEP_DELAY_SECONDS=3             # seconds between steps

# ── Dashboard Auth ────────────────────────────
JWT_SECRET=CHANGE_ME_RANDOM_STRING_64_CHARS
DASHBOARD_PASSWORD=CHANGE_ME

# ── Watched Symbols ──────────────────────────
WATCHED_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT,ARB/USDT,DOGE/USDT
